# DraftFi backend configuration (copy to .env and edit)

# SQLite database file (relative to backend working dir). Holds transactions,
# categorization cache, sandbox branches, AND the LLM provider config + API keys.
DRAFTFI_DB_PATH=sandbox.db

# Comma-separated list of allowed CORS origins for the frontend
DRAFTFI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# NOTE: LLM provider, model, base URL, and API keys are configured at runtime
# from the app's "LLM Provider" panel and stored in the database — not here.
